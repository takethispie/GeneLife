@page "/grocery-stores"
@using Genelife.AdminFrontend.Models
@using Genelife.AdminFrontend.Services
@using Microsoft.AspNetCore.SignalR.Client
@inject GroceryHubService HubService
@inject GroceryApiService ApiService
@implements IAsyncDisposable

<PageTitle>Grocery Stores</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Live Grocery Stores</MudText>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudChip T="string"
             Color="@(connectionState == HubConnectionState.Connected ? Color.Success : Color.Error)"
             Icon="@(connectionState == HubConnectionState.Connected ? Icons.Material.Filled.Wifi : Icons.Material.Filled.WifiOff)">
        @connectionState
    </MudChip>
    <MudText Typo="Typo.body2" Color="Color.Secondary">@stores.Count store(s) tracked</MudText>
</MudStack>

@if (stores.Count == 0)
{
    <MudAlert Severity="Severity.Info">Waiting for grocery store updates…</MudAlert>
}
else
{
    <MudGrid>
        @foreach (var store in stores.Values.OrderByDescending(s => s.Revenue))
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.StoreMallDirectory" Class="mr-1" />
                                Store
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @store.CorrelationId.ToString()
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">
                                @store.CustomerCount customer(s)
                            </MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid Spacing="1">
                            <MudItem xs="6">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Revenue</MudText>
                                    <MudText Typo="Typo.body2">@store.Revenue.ToString("C0")</MudText>
                                </MudStack>
                            </MudItem>
                            <MudItem xs="6">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Customers</MudText>
                                    <MudText Typo="Typo.body2">@store.CustomerCount</MudText>
                                </MudStack>
                            </MudItem>
                            <MudItem xs="6">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Food Price</MudText>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                                       Size="Size.Small"
                                                       Variant="Variant.Outlined"
                                                       Color="Color.Error"
                                                       Disabled="@(store.FoodPrice <= 1)"
                                                       OnClick="@(() => AdjustFoodPrice(store.CorrelationId, store.FoodPrice - 1))" />
                                        <MudText Typo="Typo.body2" Style="min-width:2rem;text-align:center">@store.FoodPrice.ToString("C0")</MudText>
                                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                                       Size="Size.Small"
                                                       Variant="Variant.Outlined"
                                                       Color="Color.Success"
                                                       OnClick="@(() => AdjustFoodPrice(store.CorrelationId, store.FoodPrice + 1))" />
                                    </MudStack>
                                </MudStack>
                            </MudItem>
                            <MudItem xs="6">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Drink Price</MudText>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                                       Size="Size.Small"
                                                       Variant="Variant.Outlined"
                                                       Color="Color.Error"
                                                       Disabled="@(store.DrinkPrice <= 1)"
                                                       OnClick="@(() => AdjustDrinkPrice(store.CorrelationId, store.DrinkPrice - 1))" />
                                        <MudText Typo="Typo.body2" Style="min-width:2rem;text-align:center">@store.DrinkPrice.ToString("C0")</MudText>
                                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                                       Size="Size.Small"
                                                       Variant="Variant.Outlined"
                                                       Color="Color.Success"
                                                       OnClick="@(() => AdjustDrinkPrice(store.CorrelationId, store.DrinkPrice + 1))" />
                                    </MudStack>
                                </MudStack>
                            </MudItem>
                        </MudGrid>
                        <MudDivider Class="mt-2 mb-1" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Position (@store.X, @store.Y, @store.Z)
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private readonly Dictionary<Guid, GroceryUpdateDto> stores = [];
    private HubConnectionState connectionState = HubConnectionState.Disconnected;

    protected override async Task OnInitializedAsync()
    {
        HubService.OnGroceryUpdate += HandleGroceryUpdate;
        await HubService.StartAsync();
        connectionState = HubService.State;
        StateHasChanged();
    }

    private void HandleGroceryUpdate(GroceryUpdateDto dto)
    {
        stores[dto.CorrelationId] = dto;
        connectionState = HubService.State;
        InvokeAsync(StateHasChanged);
    }

    private async Task AdjustFoodPrice(Guid storeId, int newPrice)
    {
        if (newPrice < 1) return;
        await ApiService.SetPriceAsync(storeId, foodPrice: newPrice, drinkPrice: null);
    }

    private async Task AdjustDrinkPrice(Guid storeId, int newPrice)
    {
        if (newPrice < 1) return;
        await ApiService.SetPriceAsync(storeId, foodPrice: null, drinkPrice: newPrice);
    }

    public async ValueTask DisposeAsync()
    {
        HubService.OnGroceryUpdate -= HandleGroceryUpdate;
        await Task.CompletedTask;
    }
}
