@using MudBlazor

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
    <MudIcon Icon="@Icon" Size="Size.Small" Color="@Color" Style="width:18px" />
    <MudText Typo="Typo.caption" Style="width:52px">@Label</MudText>
    <MudProgressLinear Color="@Color"
                       Value="@Value"
                       Min="0"
                       Max="100"
                       Rounded="true"
                       Size="Size.Small"
                       Class="flex-1" />
    <MudText Typo="Typo.caption" Style="width:36px;text-align:right">@Value.ToString("F0")</MudText>
</MudStack>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter, EditorRequired] public float Value { get; set; }
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Circle;
}
